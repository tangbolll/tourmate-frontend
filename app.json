{
  "expo": {
    "name": "tourmate-frontend",
    "slug": "tourmate-frontend",
    "owner": "seoyeon88",
    "icon": "./assets/icon.png",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tourmate.tourmate"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.anonymous.tourmatefrontend"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to let you share them with your friends."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true,
            "extraMavenRepos": [
              "https://devrepo.kakao.com/nexus/content/groups/public/"
            ],
            "manifestApplicationAttributes": {
              "com.kakao.sdk.AppKey": "bf2ed7b5e3276022c9ad3ce91414cdb8"
            }
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "API_BASE_URL_DEV": "http://192.168.0.47:8080",
      "API_BASE_URL_LOCAL": "http://192.168.0.47:8080",
      "router": {
        "origin": false
      },
      "API_BASE_URL_PROD": "http://192.168.0.47:8080",
      "eas": {
        "projectId": "2febce94-551e-4e11-a994-fcf972f73929"
      }
    }
  }
}
